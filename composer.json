{
    "name": "l2ernestoo/facturalesgt",
    "description": "Reusable Laravel package for Guatemalan FEL certification.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Lc\\Fel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lc\\Fel\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-simplexml": "*",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/encryption": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "nesbot/carbon": "^2.72|^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lc\\Fel\\Providers\\FelServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
